{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "existing-token"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "existing-bash-hook"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "GENKI_HOOK_ID=deny_nested_agent_2; existing-second-managed-block"
          }
        ]
      }
    ]
  }
}
